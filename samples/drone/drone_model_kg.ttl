:prop_fps                 a sysmlkg:ValueProperty ; rdfs:label "fps" ;
    sysmlkg:value "30.0"^^xsd:double ; sysmlkg:unit "fps" .
:prop_fovDeg              a sysmlkg:ValueProperty ; rdfs:label "fovDeg" ;
    sysmlkg:value "84.0"^^xsd:double ; sysmlkg:unit "deg" .
:prop_stabilAccuracyDeg   a sysmlkg:ValueProperty ; rdfs:label "stabilAccuracyDeg" ;
    sysmlkg:value "0.01"^^xsd:double ; sysmlkg:unit "deg" .
:prop_tiltRangeDeg        a sysmlkg:ValueProperty ; rdfs:label "tiltRangeDeg" ;
    sysmlkg:value "90.0"^^xsd:double ; sysmlkg:unit "deg" .

# -----------------------------------------------------------------------------
# Port Nodes
# -----------------------------------------------------------------------------

:port_RCInput         a sysmlkg:Port ; rdfs:label "rcInput" ;
    rdfs:comment "SBUS RC uplink input to FCU." .
:port_SensorBus       a sysmlkg:Port ; rdfs:label "sensorBus" ;
    rdfs:comment "Internal sensor data bus IMU/baro/GNSS to FCU." .
:port_MotorBus        a sysmlkg:Port ; rdfs:label "motorBus" ;
    rdfs:comment "DSHOT motor command bus from FCU to ESCs." .
:port_MAVLinkOutput   a sysmlkg:Port ; rdfs:label "mavlinkOut" ;
    rdfs:comment "MAVLink 2.0 stream from FCU to telemetry transceiver." .
:port_PowerOutput     a sysmlkg:Port ; rdfs:label "powerOut" ;
    rdfs:comment "25.2 V battery bus output to ESCs and avionics." .
:port_TelemetryOutput a sysmlkg:Port ; rdfs:label "telemetryOut" ;
    rdfs:comment "RF telemetry downlink to ground station." .
:port_RCOutput        a sysmlkg:Port ; rdfs:label "rcOut" ;
    rdfs:comment "Decoded RC commands to FCU." .
:port_PositionOutput  a sysmlkg:Port ; rdfs:label "positionOut" ;
    rdfs:comment "EKF position/velocity/attitude solution." .
:port_PayloadPower    a sysmlkg:Port ; rdfs:label "payloadPower" ;
    rdfs:comment "Regulated 12 V / 2 A payload power feed." .
:port_VideoOutput     a sysmlkg:Port ; rdfs:label "videoOut" ;
    rdfs:comment "Digital video stream to ground station." .

# -----------------------------------------------------------------------------
# BEHAVIORAL LAYER — Action Definitions
# -----------------------------------------------------------------------------

:act_PerformMission
    a sysmlkg:ActionDefinition ;
    rdfs:label "PerformMission" ;
    rdfs:comment "Top-level mission action: preflight -> takeoff -> [waypoint loop]  -> RTH -> land." ;
    sysmlkg:inPackage     :pkg_DroneSystem ;
    sysmlkg:hasSubAction  :act_Preflight ;
    sysmlkg:hasSubAction  :act_TakeOff ;
    sysmlkg:hasSubAction  :act_HoverInPlace ;
    sysmlkg:hasSubAction  :act_NavigateToWaypoint ;
    sysmlkg:hasSubAction  :act_ExecuteMissionTask ;
    sysmlkg:hasSubAction  :act_ReturnToHome ;
    sysmlkg:hasSubAction  :act_Land .

:act_Preflight
    a sysmlkg:ActionDefinition ;
    rdfs:label "Preflight" ;
    rdfs:comment "Pre-arming checks: sensor self-test, GNSS fix, ESC calibration,  battery SoC >= 30%, geofence load." ;
    sysmlkg:inPackage    :pkg_DroneSystem ;
    sysmlkg:triggersState :state_PreFlight .

:act_ArmMotors
    a sysmlkg:ActionDefinition ;
    rdfs:label "ArmMotors" ;
    rdfs:comment "Arms ESC/motor subsystem after preflight pass and throttle-low check." ;
    sysmlkg:inPackage    :pkg_DroneSystem ;
    sysmlkg:triggersState :state_MotorArmed .

:act_TakeOff
    a sysmlkg:ActionDefinition ;
    rdfs:label "TakeOff" ;
    rdfs:comment "Autonomous ascent to target hover altitude. Requires GPS fix,  SoC >= 30%, motors armed." ;
    sysmlkg:inPackage    :pkg_DroneSystem ;
    sysmlkg:triggersState :state_TakingOff ;
    sysmlkg:followedBy    :act_HoverInPlace .

:act_HoverInPlace
    a sysmlkg:ActionDefinition ;
    rdfs:label "HoverInPlace" ;
    rdfs:comment "GPS position-hold at current altitude. Max drift 1.5 m CEP." ;
    sysmlkg:inPackage    :pkg_DroneSystem ;
    sysmlkg:triggersState :state_Hovering ;
    sysmlkg:followedBy    :act_NavigateToWaypoint .

:act_NavigateToWaypoint
    a sysmlkg:ActionDefinition ;
    rdfs:label "NavigateToWaypoint" ;
    rdfs:comment "Flies to target GPS waypoint at specified altitude and speed.  Executes obstacle avoidance if obstacle map is non-empty." ;
    sysmlkg:inPackage    :pkg_DroneSystem ;
    sysmlkg:triggersState :state_Navigating ;
    sysmlkg:followedBy    :act_ExecuteMissionTask .

:act_ExecuteMissionTask
    a sysmlkg:ActionDefinition ;
    rdfs:label "ExecuteMissionTask" ;
    rdfs:comment "Performs waypoint task: capture image, loiter, or trigger payload." ;
    sysmlkg:inPackage   :pkg_DroneSystem ;
    sysmlkg:followedBy  :act_NavigateToWaypoint .

:act_ReturnToHome
    a sysmlkg:ActionDefinition ;
    rdfs:label "ReturnToHome" ;
    rdfs:comment "Climbs to RTH altitude (30 m), flies to home position, descends." ;
    sysmlkg:inPackage    :pkg_DroneSystem ;
    sysmlkg:triggersState :state_ReturnHome ;
    sysmlkg:followedBy    :act_Land .

:act_Land
    a sysmlkg:ActionDefinition ;
    rdfs:label "Land" ;
    rdfs:comment "Controlled autonomous descent. Detects ground contact via  barometer/IMU; cuts motors on touch-down." ;
    sysmlkg:inPackage    :pkg_DroneSystem ;
    sysmlkg:triggersState :state_Landing ;
    sysmlkg:followedBy    :act_DisarmMotors .

:act_EmergencyLanding
    a sysmlkg:ActionDefinition ;
    rdfs:label "EmergencyLanding" ;
    rdfs:comment "Immediate controlled descent triggered by critical battery (SoC < 5%)  or hardware fault. Overrides current mission phase." ;
    sysmlkg:inPackage    :pkg_DroneSystem ;
    sysmlkg:triggersState :state_Emergency .

:act_DisarmMotors
    a sysmlkg:ActionDefinition ;
    rdfs:label "DisarmMotors" ;
    rdfs:comment "Disarms ESC/motor subsystem after landing or on pilot command." ;
    sysmlkg:inPackage    :pkg_DroneSystem ;
    sysmlkg:triggersState :state_Grounded .

:act_RunAttitudeController
    a sysmlkg:ActionDefinition ;
    rdfs:label "RunAttitudeController" ;
    rdfs:comment "Cascaded PID attitude loop at 400 Hz. Computes per-motor thrust." ;
    sysmlkg:inPackage   :pkg_DroneSystem ;
    sysmlkg:performedBy :AttitudeController .

:act_RunPositionController
    a sysmlkg:ActionDefinition ;
    rdfs:label "RunPositionController" ;
    rdfs:comment "Computes attitude setpoint from position/velocity error at 50 Hz." ;
    sysmlkg:inPackage   :pkg_DroneSystem ;
    sysmlkg:performedBy :WaypointNavigator ;
    sysmlkg:followedBy  :act_RunAttitudeController .

:act_BroadcastTelemetry
    a sysmlkg:ActionDefinition ;
    rdfs:label "BroadcastTelemetry" ;
    rdfs:comment "Transmits 10 Hz MAVLink 2.0 telemetry: position, attitude,  battery, mode, heartbeat." ;
    sysmlkg:inPackage   :pkg_DroneSystem ;
    sysmlkg:performedBy :TelemetryTransceiver .

:act_ProcessRCInput
    a sysmlkg:ActionDefinition ;
    rdfs:label "ProcessRCInput" ;
    rdfs:comment "Decodes SBUS frame; maps to attitude or velocity setpoints." ;
    sysmlkg:inPackage   :pkg_DroneSystem ;
    sysmlkg:performedBy :RCReceiver ;
    sysmlkg:followedBy  :act_RunAttitudeController .

:act_MonitorBattery
    a sysmlkg:ActionDefinition ;
    rdfs:label "MonitorBattery" ;
    rdfs:comment "Samples cell voltages at 1 Hz; runs SoC estimation;  publishes failsafe events on threshold crossings." ;
    sysmlkg:inPackage   :pkg_DroneSystem ;
    sysmlkg:performedBy :BatteryPack .

:act_DetectObstacles
    a sysmlkg:ActionDefinition ;
    rdfs:label "DetectObstacles" ;
    rdfs:comment "Processes ToF data at 20 Hz; publishes obstacle map." ;
    sysmlkg:inPackage   :pkg_DroneSystem ;
    sysmlkg:performedBy :ObstacleDetector ;
    sysmlkg:followedBy  :act_NavigateToWaypoint .

:act_EstimateState
    a sysmlkg:ActionDefinition ;
    rdfs:label "EstimateState" ;
    rdfs:comment "EKF fusing IMU (400 Hz), GNSS (10 Hz), barometer (50 Hz)." ;
    sysmlkg:inPackage   :pkg_DroneSystem ;
    sysmlkg:performedBy :NavigationSystem ;
    sysmlkg:followedBy  :act_RunPositionController .

:act_EnforceGeofence
    a sysmlkg:ActionDefinition ;
    rdfs:label "EnforceGeofence" ;
    rdfs:comment "Checks position against geofence polygons; commands RTH or hover  if boundary approached." ;
    sysmlkg:inPackage   :pkg_DroneSystem ;
    sysmlkg:performedBy :FailsafeManager .

# -----------------------------------------------------------------------------
# BEHAVIORAL LAYER — State Definitions
# -----------------------------------------------------------------------------

:state_DroneOperationalState
    a sysmlkg:StateDefinition ;
    rdfs:label "DroneOperationalState" ;
    rdfs:comment "Top-level operational state machine." ;
    sysmlkg:inPackage :pkg_DroneSystem ;
    sysmlkg:hasState  :state_Grounded ;
    sysmlkg:hasState  :state_PreFlight ;
    sysmlkg:hasState  :state_TakingOff ;
    sysmlkg:hasState  :state_Hovering ;
    sysmlkg:hasState  :state_Navigating ;
    sysmlkg:hasState  :state_ReturnHome ;
    sysmlkg:hasState  :state_Landing ;
    sysmlkg:hasState  :state_Emergency .

:state_Grounded
    a sysmlkg:State ;
    rdfs:label "Grounded" ;
    rdfs:comment "On ground, motors disarmed. Initial post-power-on state." ;
    sysmlkg:transitionsTo :state_PreFlight ;
    sysmlkg:transitionGuard "arm_command_received AND preflight_checks_passed" .

:state_PreFlight
    a sysmlkg:State ;
    rdfs:label "PreFlight" ;
    rdfs:comment "Running sensor self-test, GNSS fix, ESC check, SoC >= 30%." ;
    sysmlkg:transitionsTo :state_TakingOff ;
    sysmlkg:transitionGuard "preflight_ok AND takeoff_command" .

:state_TakingOff
    a sysmlkg:State ;
    rdfs:label "TakingOff" ;
    rdfs:comment "Ascending to target hover altitude." ;
    sysmlkg:transitionsTo :state_Hovering ;
    sysmlkg:transitionGuard "altitude_reached WITHIN 0.5m" .

:state_Hovering
    a sysmlkg:State ;
    rdfs:label "Hovering" ;
    rdfs:comment "GPS position-hold at altitude. Stable inter-waypoint state." ;
    sysmlkg:transitionsTo :state_Navigating ;
    sysmlkg:transitionGuard "next_waypoint_command" .

:state_Navigating
    a sysmlkg:State ;
    rdfs:label "Navigating" ;
    rdfs:comment "Flying towards target waypoint." ;
    sysmlkg:transitionsTo :state_Hovering ;
    sysmlkg:transitionGuard "waypoint_arrived" .

:state_ReturnHome
    a sysmlkg:State ;
    rdfs:label "ReturnHome" ;
    rdfs:comment "RTH: climb to RTH altitude, fly to home, prepare to land." ;
    sysmlkg:transitionsTo :state_Landing ;
    sysmlkg:transitionGuard "home_position_reached" .

:state_Landing
    a sysmlkg:State ;
    rdfs:label "Landing" ;
    rdfs:comment "Controlled descent. Transitions to Grounded on touch-down." ;
    sysmlkg:transitionsTo :state_Grounded ;
    sysmlkg:transitionGuard "touchdown_detected" .

:state_Emergency
    a sysmlkg:State ;
    rdfs:label "Emergency" ;
    rdfs:comment "Critical fault: triggers EmergencyLanding immediately." ;
    sysmlkg:transitionsTo :state_Grounded ;
    sysmlkg:transitionGuard "emergency_landing_complete" .

:state_MotorState
    a sysmlkg:StateDefinition ;
    rdfs:label "MotorState" ;
    sysmlkg:inPackage :pkg_DroneSystem ;
    sysmlkg:hasState  :state_MotorDisarmed ;
    sysmlkg:hasState  :state_MotorArmed ;
    sysmlkg:hasState  :state_MotorRunning ;
    sysmlkg:hasState  :state_MotorFaultStop .

:state_MotorDisarmed  a sysmlkg:State ; rdfs:label "Disarmed" ;
    rdfs:comment "Motors safe; no thrust." .
:state_MotorArmed     a sysmlkg:State ; rdfs:label "Armed" ;
    rdfs:comment "Throttle commands accepted." .
:state_MotorRunning   a sysmlkg:State ; rdfs:label "Running" ;
    rdfs:comment "Motors spinning; drone in flight." .
:state_MotorFaultStop a sysmlkg:State ; rdfs:label "FaultStop" ;
    rdfs:comment "Motor fault detected; motor stopped for safety." .

:state_BatteryState
    a sysmlkg:StateDefinition ;
    rdfs:label "BatteryState" ;
    sysmlkg:inPackage :pkg_DroneSystem ;
    sysmlkg:hasState  :state_BattNormal ;
    sysmlkg:hasState  :state_BattLow ;
    sysmlkg:hasState  :state_BattCritical ;
    sysmlkg:hasState  :state_BattEmergency .

:state_BattNormal    a sysmlkg:State ; rdfs:label "Normal" ;
    rdfs:comment "SoC > 20%. Normal operation." .
:state_BattLow       a sysmlkg:State ; rdfs:label "LowBattery" ;
    rdfs:comment "SoC 15-20%. RTH warning." .
:state_BattCritical  a sysmlkg:State ; rdfs:label "Critical" ;
    rdfs:comment "SoC 5-15%. RTH commanded." .
:state_BattEmergency a sysmlkg:State ; rdfs:label "Emergency" ;
    rdfs:comment "SoC < 5%. Auto-land commanded." .

# -----------------------------------------------------------------------------
# EMBEDDED REQUIREMENTS
# -----------------------------------------------------------------------------

:req_SafetyAltitudeReq
    a sysmlkg:Requirement ;
    rdfs:label "SafetyAltitudeReq" ;
    sysmlkg:requirementId   "DRONE-SYS-002" ;
    sysmlkg:requirementText "The drone system shall not exceed 120 m altitude above  ground level under autonomous control in standard mode." ;
    sysmlkg:inPackage :pkg_DroneSystem .

:req_EnduranceReq
    a sysmlkg:Requirement ;
    rdfs:label "EnduranceReq" ;
    sysmlkg:requirementId   "DRONE-SYS-004" ;
    sysmlkg:requirementText "The drone system shall achieve a minimum of 30 minutes  of continuous hover flight at maximum rated payload." ;
    sysmlkg:inPackage :pkg_DroneSystem .

:req_LinkBudgetReq
    a sysmlkg:Requirement ;
    rdfs:label "LinkBudgetReq" ;
    sysmlkg:requirementId   "DRONE-COM-001" ;
    sysmlkg:requirementText "The communication system shall maintain a minimum link  budget margin of 6 dB at 1000 m slant range." ;
    sysmlkg:inPackage :pkg_DroneSystem .

:req_PositionAccuracyReq
    a sysmlkg:Requirement ;
    rdfs:label "PositionAccuracyReq" ;
    sysmlkg:requirementId   "DRONE-NAV-001" ;
    sysmlkg:requirementText "The navigation system shall provide position estimates  with CEP <= 1.5 m under open-sky dual-band GNSS." ;
    sysmlkg:inPackage :pkg_DroneSystem .

:req_FailsafeReq
    a sysmlkg:Requirement ;
    rdfs:label "FailsafeReq" ;
    sysmlkg:requirementId   "DRONE-FSF-001" ;
    sysmlkg:requirementText "The FCU shall initiate return-to-home within 2 seconds  of detecting a continuous RC link loss." ;
    sysmlkg:inPackage :pkg_DroneSystem .

:req_ThrustMarginReq
    a sysmlkg:Requirement ;
    rdfs:label "ThrustMarginReq" ;
    sysmlkg:requirementId   "DRONE-SYS-001" ;
    sysmlkg:requirementText "The propulsion system shall deliver a thrust-to-weight  ratio of at least 2.0 at maximum all-up weight of 2.0 kg." ;
    sysmlkg:inPackage :pkg_DroneSystem .

:req_PayloadInterfaceReq
    a sysmlkg:Requirement ;
    rdfs:label "PayloadInterfaceReq" ;
    sysmlkg:requirementId   "DRONE-PLD-001" ;
    sysmlkg:requirementText "The payload interface shall accept payloads up to 500 g  and supply 12 V / 2 A regulated power during flight." ;
    sysmlkg:inPackage :pkg_DroneSystem .

# -----------------------------------------------------------------------------
# Package node
# -----------------------------------------------------------------------------

:pkg_DroneSystem
    a sysmlkg:Package ;
    rdfs:label "DroneSystem" ;
    rdfs:comment "Top-level SysML v2 package containing the complete drone model." .
