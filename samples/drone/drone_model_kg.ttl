:prop_stateOfCharge       a sysmlkg:ValueProperty ; rdfs:label "stateOfCharge" ;
    sysmlkg:value "1.0"^^xsd:double .
:prop_avionicsVoltV       a sysmlkg:ValueProperty ; rdfs:label "avionicsVoltV" ;
    sysmlkg:value "5.0"^^xsd:double ; sysmlkg:unit "V" .
