:prop_rthSoCThreshold     a sysmlkg:ValueProperty ; rdfs:label "rthSoCThreshold" ;
    sysmlkg:value "0.20"^^xsd:double .
:prop_autoLandSoCThresh   a sysmlkg:ValueProperty ; rdfs:label "autoLandSoCThresh" ;
    sysmlkg:value "0.05"^^xsd:double .
:prop_maxAltitudeLimitM   a sysmlkg:ValueProperty ; rdfs:label "maxAltitudeLimitM" ;
    sysmlkg:value "120.0"^^xsd:double ; sysmlkg:unit "m" .
