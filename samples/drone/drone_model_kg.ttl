# =============================================================================
# Drone System Knowledge Graph
# Ontology: sysmlkg: <http://reqgraph.io/sysml/>
# Generated from drone_model.sysml (SysML v2 structural + behavioral model)
# =============================================================================

@prefix sysmlkg: <http://reqgraph.io/sysml/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix :        <http://example.org/drone#> .

# -----------------------------------------------------------------------------
# Ontology declaration
# -----------------------------------------------------------------------------

<http://example.org/drone>
    a owl:Ontology ;
    rdfs:label "Drone System Knowledge Graph" ;
    rdfs:comment "Structural and behavioral knowledge graph of an autonomous  multi-rotor drone modelled in SysML v2." .

# -----------------------------------------------------------------------------
# STRUCTURAL LAYER — Part Definitions (Blocks)
# -----------------------------------------------------------------------------

# Top-level system
:DroneSystem
    a sysmlkg:Block ;
    rdfs:label "DroneSystem" ;
    rdfs:comment "Top-level autonomous drone system integrating propulsion, power,  avionics, communication, navigation, and payload subsystems." ;
    sysmlkg:inPackage         :pkg_DroneSystem ;
    sysmlkg:hasProperty       :prop_maxSpeed ;
    sysmlkg:hasProperty       :prop_maxAltitude ;
    sysmlkg:hasProperty       :prop_endurance ;
    sysmlkg:hasProperty       :prop_payloadCapacity ;
    sysmlkg:hasProperty       :prop_maxAllUpWeight ;
    sysmlkg:hasPart           :FlightControlUnit ;
    sysmlkg:hasPart           :PowerSystem ;
    sysmlkg:hasPart           :PropulsionSystem ;
    sysmlkg:hasPart           :CommunicationModule ;
    sysmlkg:hasPart           :NavigationSystem ;
    sysmlkg:hasPart           :PayloadSystem ;
    sysmlkg:satisfies         :req_EnduranceReq ;
    sysmlkg:satisfies         :req_SafetyAltitudeReq .

# -- Flight Control Subsystem --------------------------------------------------

:FlightControlUnit
    a sysmlkg:Block ;
    rdfs:label "FlightControlUnit" ;
    rdfs:comment "Autopilot: fuses sensor data, runs attitude/position controllers,  executes waypoint missions, and handles failsafe responses." ;
    sysmlkg:inPackage         :pkg_DroneSystem ;
    sysmlkg:hasPart           :AttitudeController ;
    sysmlkg:hasPart           :WaypointNavigator ;
    sysmlkg:hasPart           :FailsafeManager ;
    sysmlkg:hasPort           :port_RCInput ;
    sysmlkg:hasPort           :port_SensorBus ;
    sysmlkg:hasPort           :port_MotorBus ;
    sysmlkg:hasPort           :port_MAVLinkOutput ;
    sysmlkg:satisfies         :req_FailsafeReq .

:AttitudeController
    a sysmlkg:Block ;
    rdfs:label "AttitudeController" ;
    rdfs:comment "Cascaded PID attitude stabiliser with feed-forward.  Inner rate loop bandwidth >= 15 Hz." ;
    sysmlkg:inPackage   :pkg_DroneSystem ;
    sysmlkg:hasProperty :prop_rollKp ;
    sysmlkg:hasProperty :prop_pitchKp ;
    sysmlkg:hasProperty :prop_yawKp ;
    sysmlkg:hasProperty :prop_loopRateHz .

:WaypointNavigator
    a sysmlkg:Block ;
    rdfs:label "WaypointNavigator" ;
    rdfs:comment "GPS-guided waypoint mission executor. Cross-track error <= 2 m." ;
    sysmlkg:inPackage   :pkg_DroneSystem ;
    sysmlkg:hasProperty :prop_maxWaypoints ;
    sysmlkg:hasProperty :prop_crossTrackMaxM .

:FailsafeManager
    a sysmlkg:Block ;
    rdfs:label "FailsafeManager" ;
    rdfs:comment "Monitors RC link, battery SoC, and geofence; triggers RTH or auto-land." ;
    sysmlkg:inPackage   :pkg_DroneSystem ;
    sysmlkg:hasProperty :prop_linkLossTimeout ;
    sysmlkg:hasProperty :prop_rthSoCThreshold ;
    sysmlkg:hasProperty :prop_autoLandSoCThresh ;
    sysmlkg:hasProperty :prop_maxAltitudeLimitM .

# -- Power Subsystem -----------------------------------------------------------

:PowerSystem
    a sysmlkg:Block ;
    rdfs:label "PowerSystem" ;
    rdfs:comment "Battery pack plus power distribution board.  Supplies 25.2 V bus and regulated 5 V avionics rail." ;
    sysmlkg:inPackage :pkg_DroneSystem ;
    sysmlkg:hasPart   :BatteryPack ;
    sysmlkg:hasPart   :PowerDistributionBoard ;
    sysmlkg:hasPort   :port_PowerOutput .

:BatteryPack
    a sysmlkg:Block ;
    rdfs:label "BatteryPack" ;
    rdfs:comment "LiPo 6S 5000 mAh 22.2 V. BMS protects against overcharge and  over-discharge. Minimum 200 charge cycles." ;
    sysmlkg:inPackage   :pkg_DroneSystem ;
    sysmlkg:hasProperty :prop_nominalVoltageV ;
    sysmlkg:hasProperty :prop_capacityAh ;
    sysmlkg:hasProperty :prop_energyWh ;
    sysmlkg:hasProperty :prop_minCycles ;
    sysmlkg:hasProperty :prop_stateOfCharge .

:PowerDistributionBoard
    a sysmlkg:Block ;
    rdfs:label "PowerDistributionBoard" ;
    rdfs:comment "Routes 25.2 V to four ESC rails; provides 5 V regulated avionics bus." ;
    sysmlkg:inPackage   :pkg_DroneSystem ;
    sysmlkg:hasProperty :prop_avionicsVoltV ;
    sysmlkg:hasProperty :prop_maxCurrentA_pdb .

# -- Propulsion Subsystem ------------------------------------------------------

:PropulsionSystem
    a sysmlkg:Block ;
    rdfs:label "PropulsionSystem" ;
    rdfs:comment "Quadrotor X-frame: 4 x (brushless motor + propeller + ESC).  Thrust-to-weight ratio >= 2:1 at MTOW." ;
    sysmlkg:inPackage :pkg_DroneSystem ;
    sysmlkg:hasPart   :BrushlessMotor ;
    sysmlkg:hasPart   :Propeller ;
    sysmlkg:hasPart   :ESC ;
    sysmlkg:satisfies :req_ThrustMarginReq .

:BrushlessMotor
    a sysmlkg:Block ;
    rdfs:label "BrushlessMotor" ;
    rdfs:comment "KV920 brushless DC motor. Static thrust >= 500 g. Operating temp 0-60 C." ;
    sysmlkg:inPackage   :pkg_DroneSystem ;
    sysmlkg:hasProperty :prop_kv ;
    sysmlkg:hasProperty :prop_maxThrustG ;
    sysmlkg:hasProperty :prop_maxTempC .

:Propeller
    a sysmlkg:Block ;
    rdfs:label "Propeller" ;
    rdfs:comment "10-inch 4.5-pitch carbon-fibre two-blade propeller." ;
    sysmlkg:inPackage   :pkg_DroneSystem ;
    sysmlkg:hasProperty :prop_diameterIn ;
    sysmlkg:hasProperty :prop_pitchIn .

:ESC
    a sysmlkg:Block ;
    rdfs:label "ESC" ;
    rdfs:comment "40 A DSHOT-compatible electronic speed controller. Response <= 5 ms." ;
    sysmlkg:inPackage   :pkg_DroneSystem ;
    sysmlkg:hasProperty :prop_maxCurrentA_esc ;
    sysmlkg:hasProperty :prop_responseTimeMs .

# -- Communication Subsystem ---------------------------------------------------

:CommunicationModule
    a sysmlkg:Block ;
    rdfs:label "CommunicationModule" ;
    rdfs:comment "FHSS RC uplink (SBUS) and MAVLink 2.0 telemetry downlink.  RC latency <= 20 ms; telemetry range >= 1000 m." ;
    sysmlkg:inPackage :pkg_DroneSystem ;
    sysmlkg:hasPart   :RCReceiver ;
    sysmlkg:hasPart   :TelemetryTransceiver ;
    sysmlkg:hasPort   :port_TelemetryOutput ;
    sysmlkg:hasPort   :port_RCOutput ;
    sysmlkg:satisfies :req_LinkBudgetReq .

:RCReceiver
    a sysmlkg:Block ;
    rdfs:label "RCReceiver" ;
    rdfs:comment "2.4 GHz FHSS RC receiver. SBUS output at 100 Hz. 16 channels." ;
    sysmlkg:inPackage   :pkg_DroneSystem ;
    sysmlkg:hasProperty :prop_rcFreqMHz ;
    sysmlkg:hasProperty :prop_channels ;
    sysmlkg:hasProperty :prop_rcLatencyMs .

:TelemetryTransceiver
    a sysmlkg:Block ;
    rdfs:label "TelemetryTransceiver" ;
    rdfs:comment "915 MHz MAVLink 2.0 half-duplex transceiver. AES-128 encrypted  command channel. Range >= 1000 m. Data rate 57.6 kbps." ;
    sysmlkg:inPackage   :pkg_DroneSystem ;
    sysmlkg:hasProperty :prop_telFreqMHz ;
    sysmlkg:hasProperty :prop_rangeM ;
    sysmlkg:hasProperty :prop_dataRateKbps ;
    sysmlkg:hasProperty :prop_linkMarginDb .

# -- Navigation Subsystem -----------------------------------------------------

:NavigationSystem
    a sysmlkg:Block ;
    rdfs:label "NavigationSystem" ;
    rdfs:comment "EKF-fused GNSS/IMU/baro navigation. Obstacle detection and geofencing." ;
    sysmlkg:inPackage :pkg_DroneSystem ;
    sysmlkg:hasPart   :GNSSReceiver ;
    sysmlkg:hasPart   :ImuSensor ;
    sysmlkg:hasPart   :Barometer ;
    sysmlkg:hasPart   :ObstacleDetector ;
    sysmlkg:hasPort   :port_PositionOutput ;
    sysmlkg:satisfies :req_PositionAccuracyReq .

:GNSSReceiver
    a sysmlkg:Block ;
    rdfs:label "GNSSReceiver" ;
    rdfs:comment "Dual-band GPS+GLONASS. CEP <= 1.5 m. Cold fix <= 30 s." ;
    sysmlkg:inPackage   :pkg_DroneSystem ;
    sysmlkg:hasProperty :prop_cepM ;
    sysmlkg:hasProperty :prop_coldFixSec ;
    sysmlkg:hasProperty :prop_gnssUpdateRateHz .

:ImuSensor
    a sysmlkg:Block ;
    rdfs:label "ImuSensor" ;
    rdfs:comment "6-axis MEMS IMU. Sample rate >= 400 Hz." ;
    sysmlkg:inPackage   :pkg_DroneSystem ;
    sysmlkg:hasProperty :prop_imuSampleRateHz ;
    sysmlkg:hasProperty :prop_gyroRangeDps ;
    sysmlkg:hasProperty :prop_accelRangeG .

:Barometer
    a sysmlkg:Block ;
    rdfs:label "Barometer" ;
    rdfs:comment "Barometric pressure sensor. Altitude accuracy +-0.5 m static." ;
    sysmlkg:inPackage   :pkg_DroneSystem ;
    sysmlkg:hasProperty :prop_altAccuracyM ;
    sysmlkg:hasProperty :prop_baroSampleRateHz .

:ObstacleDetector
    a sysmlkg:Block ;
    rdfs:label "ObstacleDetector" ;
    rdfs:comment "ToF/ultrasonic sensor. Detection range >= 5 m. 20 Hz update rate." ;
    sysmlkg:inPackage   :pkg_DroneSystem ;
    sysmlkg:hasProperty :prop_detectionRangeM ;
    sysmlkg:hasProperty :prop_obsUpdateRateHz .

# -- Payload Subsystem ---------------------------------------------------------

:PayloadSystem
    a sysmlkg:Block ;
    rdfs:label "PayloadSystem" ;
    rdfs:comment "Stabilised camera payload. Accepts up to 500 g. Provides 12 V/2 A." ;
    sysmlkg:inPackage :pkg_DroneSystem ;
    sysmlkg:hasPart   :Camera ;
    sysmlkg:hasPart   :Gimbal ;
    sysmlkg:hasPort   :port_PayloadPower ;
    sysmlkg:hasPort   :port_VideoOutput ;
    sysmlkg:satisfies :req_PayloadInterfaceReq .

:Camera
    a sysmlkg:Block ;
    rdfs:label "Camera" ;
    rdfs:comment "4K / 30 fps CMOS camera. FOV 84 deg horizontal." ;
    sysmlkg:inPackage   :pkg_DroneSystem ;
    sysmlkg:hasProperty :prop_resolutionK ;
    sysmlkg:hasProperty :prop_fps ;
    sysmlkg:hasProperty :prop_fovDeg .

:Gimbal
    a sysmlkg:Block ;
    rdfs:label "Gimbal" ;
    rdfs:comment "3-axis brushless stabilised gimbal. Accuracy +-0.01 deg." ;
    sysmlkg:inPackage   :pkg_DroneSystem ;
    sysmlkg:hasProperty :prop_stabilAccuracyDeg ;
    sysmlkg:hasProperty :prop_tiltRangeDeg .

# -----------------------------------------------------------------------------
# Property Nodes (ValueProperties / Attributes)
# -----------------------------------------------------------------------------

:prop_maxSpeed            a sysmlkg:ValueProperty ; rdfs:label "maxSpeed" ;
    sysmlkg:value "15.0"^^xsd:double ; sysmlkg:unit "m/s" .
:prop_maxAltitude         a sysmlkg:ValueProperty ; rdfs:label "maxAltitude" ;
    sysmlkg:value "120.0"^^xsd:double ; sysmlkg:unit "m AGL" .
:prop_endurance           a sysmlkg:ValueProperty ; rdfs:label "endurance" ;
    sysmlkg:value "30.0"^^xsd:double ; sysmlkg:unit "min" .
:prop_payloadCapacity     a sysmlkg:ValueProperty ; rdfs:label "payloadCapacity" ;
    sysmlkg:value "0.5"^^xsd:double ; sysmlkg:unit "kg" .
:prop_maxAllUpWeight      a sysmlkg:ValueProperty ; rdfs:label "maxAllUpWeight" ;
    sysmlkg:value "2.0"^^xsd:double ; sysmlkg:unit "kg" .
:prop_rollKp              a sysmlkg:ValueProperty ; rdfs:label "rollKp" ;
    sysmlkg:value "6.0"^^xsd:double .
:prop_pitchKp             a sysmlkg:ValueProperty ; rdfs:label "pitchKp" ;
    sysmlkg:value "6.0"^^xsd:double .
:prop_yawKp               a sysmlkg:ValueProperty ; rdfs:label "yawKp" ;
    sysmlkg:value "3.0"^^xsd:double .
:prop_loopRateHz          a sysmlkg:ValueProperty ; rdfs:label "loopRateHz" ;
    sysmlkg:value "400.0"^^xsd:double ; sysmlkg:unit "Hz" .
:prop_maxWaypoints        a sysmlkg:ValueProperty ; rdfs:label "maxWaypoints" ;
    sysmlkg:value "99.0"^^xsd:double .
:prop_crossTrackMaxM      a sysmlkg:ValueProperty ; rdfs:label "crossTrackMaxM" ;
    sysmlkg:value "2.0"^^xsd:double ; sysmlkg:unit "m" .
:prop_linkLossTimeout     a sysmlkg:ValueProperty ; rdfs:label "linkLossTimeoutSec" ;
