    sysmlkg:value "0.5"^^xsd:double ; sysmlkg:unit "m" .
:prop_baroSampleRateHz    a sysmlkg:ValueProperty ; rdfs:label "sampleRateHz" ;
    sysmlkg:value "50.0"^^xsd:double ; sysmlkg:unit "Hz" .
:prop_detectionRangeM     a sysmlkg:ValueProperty ; rdfs:label "detectionRangeM" ;
