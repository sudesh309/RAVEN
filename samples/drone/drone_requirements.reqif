          </ATTRIBUTE-VALUE-STRING>
          <ATTRIBUTE-VALUE-STRING THE-VALUE="The drone shall complete a 10-waypoint rectangular survey route covering a 100 m × 50 m area at 20 m AGL with a cross-track deviation ≤ 2 m on each segment, as recorded by the onboard GPS log.">
            <DEFINITION><ATTRIBUTE-DEFINITION-STRING-REF>_ADef_TEXT</ATTRIBUTE-DEFINITION-STRING-REF></DEFINITION>
          </ATTRIBUTE-VALUE-STRING>
          <ATTRIBUTE-VALUE-STRING THE-VALUE="Validates waypoint navigation accuracy for survey missions.">
            <DEFINITION><ATTRIBUTE-DEFINITION-STRING-REF>_ADef_RATIONALE</ATTRIBUTE-DEFINITION-STRING-REF></DEFINITION>
          </ATTRIBUTE-VALUE-STRING>
