          </ATTRIBUTE-VALUE-STRING>
          <ATTRIBUTE-VALUE-STRING THE-VALUE="The drone shall demonstrate stable hover at 10 m AGL for 5 continuous minutes in Beaufort-3 (5.5 m/s) winds with position drift ≤ 1.5 m from home point.">
            <DEFINITION><ATTRIBUTE-DEFINITION-STRING-REF>_ADef_TEXT</ATTRIBUTE-DEFINITION-STRING-REF></DEFINITION>
          </ATTRIBUTE-VALUE-STRING>
          <ATTRIBUTE-VALUE-STRING THE-VALUE="Validates attitude control and GPS hold in realistic field conditions.">
            <DEFINITION><ATTRIBUTE-DEFINITION-STRING-REF>_ADef_RATIONALE</ATTRIBUTE-DEFINITION-STRING-REF></DEFINITION>
          </ATTRIBUTE-VALUE-STRING>
