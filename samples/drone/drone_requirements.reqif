      <SPEC-OBJECT IDENTIFIER="_obj_DRONE_FSF_003" LAST-CHANGE="2026-06-25T12:00:00.000Z" LONG-NAME="DRONE-FSF-003">
        <TYPE><SPEC-OBJECT-TYPE-REF>_SOT_REQ</SPEC-OBJECT-TYPE-REF></TYPE>
        <VALUES>
          <ATTRIBUTE-VALUE-STRING THE-VALUE="DRONE-FSF-003">
            <DEFINITION><ATTRIBUTE-DEFINITION-STRING-REF>_ADef_ID</ATTRIBUTE-DEFINITION-STRING-REF></DEFINITION>
          </ATTRIBUTE-VALUE-STRING>
          <ATTRIBUTE-VALUE-STRING THE-VALUE="The system shall initiate an immediate auto-land sequence at the current position when battery SoC falls below 5%, regardless of position.">
            <DEFINITION><ATTRIBUTE-DEFINITION-STRING-REF>_ADef_TEXT</ATTRIBUTE-DEFINITION-STRING-REF></DEFINITION>
          </ATTRIBUTE-VALUE-STRING>
          <ATTRIBUTE-VALUE-STRING THE-VALUE="Last-resort protection against total power loss.">
            <DEFINITION><ATTRIBUTE-DEFINITION-STRING-REF>_ADef_RATIONALE</ATTRIBUTE-DEFINITION-STRING-REF></DEFINITION>
          </ATTRIBUTE-VALUE-STRING>
          <ATTRIBUTE-VALUE-ENUMERATION>
            <DEFINITION><ATTRIBUTE-DEFINITION-ENUMERATION-REF>_ADef_LEVEL</ATTRIBUTE-DEFINITION-ENUMERATION-REF></DEFINITION>
            <VALUES><ENUM-VALUE-REF>_EV_L4</ENUM-VALUE-REF></VALUES>
          </ATTRIBUTE-VALUE-ENUMERATION>
        </VALUES>
      </SPEC-OBJECT>
      <SPEC-OBJECT IDENTIFIER="_obj_DRONE_CPR_001" LAST-CHANGE="2026-06-25T12:00:00.000Z" LONG-NAME="DRONE-CPR-001">
        <TYPE><SPEC-OBJECT-TYPE-REF>_SOT_REQ</SPEC-OBJECT-TYPE-REF></TYPE>
        <VALUES>
          <ATTRIBUTE-VALUE-STRING THE-VALUE="DRONE-CPR-001">
            <DEFINITION><ATTRIBUTE-DEFINITION-STRING-REF>_ADef_ID</ATTRIBUTE-DEFINITION-STRING-REF></DEFINITION>
          </ATTRIBUTE-VALUE-STRING>
          <ATTRIBUTE-VALUE-STRING THE-VALUE="The ground data link shall implement the MAVLink 2.0 protocol with message signing enabled; the dialect shall include HEARTBEAT, GLOBAL_POSITION_INT, ATTITUDE, SYS_STATUS, and BATTERY_STATUS messages.">
            <DEFINITION><ATTRIBUTE-DEFINITION-STRING-REF>_ADef_TEXT</ATTRIBUTE-DEFINITION-STRING-REF></DEFINITION>
          </ATTRIBUTE-VALUE-STRING>
          <ATTRIBUTE-VALUE-STRING THE-VALUE="Interoperability with standard GCS software (QGroundControl, Mission Planner).">
            <DEFINITION><ATTRIBUTE-DEFINITION-STRING-REF>_ADef_RATIONALE</ATTRIBUTE-DEFINITION-STRING-REF></DEFINITION>
          </ATTRIBUTE-VALUE-STRING>
          <ATTRIBUTE-VALUE-ENUMERATION>
            <DEFINITION><ATTRIBUTE-DEFINITION-ENUMERATION-REF>_ADef_LEVEL</ATTRIBUTE-DEFINITION-ENUMERATION-REF></DEFINITION>
            <VALUES><ENUM-VALUE-REF>_EV_L4</ENUM-VALUE-REF></VALUES>
          </ATTRIBUTE-VALUE-ENUMERATION>
        </VALUES>
      </SPEC-OBJECT>
      <SPEC-OBJECT IDENTIFIER="_obj_DRONE_CPR_002" LAST-CHANGE="2026-06-25T12:00:00.000Z" LONG-NAME="DRONE-CPR-002">
        <TYPE><SPEC-OBJECT-TYPE-REF>_SOT_REQ</SPEC-OBJECT-TYPE-REF></TYPE>
        <VALUES>
          <ATTRIBUTE-VALUE-STRING THE-VALUE="DRONE-CPR-002">
            <DEFINITION><ATTRIBUTE-DEFINITION-STRING-REF>_ADef_ID</ATTRIBUTE-DEFINITION-STRING-REF></DEFINITION>
          </ATTRIBUTE-VALUE-STRING>
          <ATTRIBUTE-VALUE-STRING THE-VALUE="The telemetry stream shall be transmitted on the 915 MHz band at a minimum data rate of 57.6 kbps and shall achieve a link budget margin of at least 6 dB at 1000 m slant range.">
            <DEFINITION><ATTRIBUTE-DEFINITION-STRING-REF>_ADef_TEXT</ATTRIBUTE-DEFINITION-STRING-REF></DEFINITION>
          </ATTRIBUTE-VALUE-STRING>
          <ATTRIBUTE-VALUE-STRING THE-VALUE="Ensures reliable downlink with multipath and atmospheric margin.">
            <DEFINITION><ATTRIBUTE-DEFINITION-STRING-REF>_ADef_RATIONALE</ATTRIBUTE-DEFINITION-STRING-REF></DEFINITION>
          </ATTRIBUTE-VALUE-STRING>
          <ATTRIBUTE-VALUE-ENUMERATION>
            <DEFINITION><ATTRIBUTE-DEFINITION-ENUMERATION-REF>_ADef_LEVEL</ATTRIBUTE-DEFINITION-ENUMERATION-REF></DEFINITION>
            <VALUES><ENUM-VALUE-REF>_EV_L4</ENUM-VALUE-REF></VALUES>
          </ATTRIBUTE-VALUE-ENUMERATION>
        </VALUES>
      </SPEC-OBJECT>
      <SPEC-OBJECT IDENTIFIER="_obj_DRONE_CPR_003" LAST-CHANGE="2026-06-25T12:00:00.000Z" LONG-NAME="DRONE-CPR-003">
        <TYPE><SPEC-OBJECT-TYPE-REF>_SOT_REQ</SPEC-OBJECT-TYPE-REF></TYPE>
        <VALUES>
          <ATTRIBUTE-VALUE-STRING THE-VALUE="DRONE-CPR-003">
            <DEFINITION><ATTRIBUTE-DEFINITION-STRING-REF>_ADef_ID</ATTRIBUTE-DEFINITION-STRING-REF></DEFINITION>
          </ATTRIBUTE-VALUE-STRING>
          <ATTRIBUTE-VALUE-STRING THE-VALUE="The command uplink shall encrypt all payload bytes using AES-128 in CBC mode with a session key derived from a pre-shared key via HKDF-SHA256; a new session key shall be generated on every power-on.">
            <DEFINITION><ATTRIBUTE-DEFINITION-STRING-REF>_ADef_TEXT</ATTRIBUTE-DEFINITION-STRING-REF></DEFINITION>
          </ATTRIBUTE-VALUE-STRING>
          <ATTRIBUTE-VALUE-STRING THE-VALUE="Prevents replay attacks and command injection.">
            <DEFINITION><ATTRIBUTE-DEFINITION-STRING-REF>_ADef_RATIONALE</ATTRIBUTE-DEFINITION-STRING-REF></DEFINITION>
          </ATTRIBUTE-VALUE-STRING>
          <ATTRIBUTE-VALUE-ENUMERATION>
            <DEFINITION><ATTRIBUTE-DEFINITION-ENUMERATION-REF>_ADef_LEVEL</ATTRIBUTE-DEFINITION-ENUMERATION-REF></DEFINITION>
            <VALUES><ENUM-VALUE-REF>_EV_L4</ENUM-VALUE-REF></VALUES>
          </ATTRIBUTE-VALUE-ENUMERATION>
        </VALUES>
      </SPEC-OBJECT>
